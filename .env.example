# ─── AI (required for /api/ask) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional overrides (defaults in src/lib/ask/service/provider.ts)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# ─── Branding (browser-safe; optional — defaults match local product name) ───
NEXT_PUBLIC_APP_NAME=verify.trading
# NEXT_PUBLIC_SITE_TITLE=verify.trading — Ask for traders
# NEXT_PUBLIC_SITE_DESCRIPTION=Your short SEO description.
# NEXT_PUBLIC_ONBOARDING_CALL_URL=https://calendly.com/your-team/10-minute-onboarding

# ─── Supabase (Auth, sessions, messages, image storage) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe billing (server-only unless NEXT_PUBLIC_*) ─────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO_MONTHLY_PROMO=price_...
# STRIPE_PROMO_COUPON_ID=coupon_...
# STRIPE_PRICE_PRO_MONTHLY_STANDARD=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PORTAL_CONFIGURATION_ID=bpc_...
# STRIPE_PROMO_END_AT=2026-06-06T00:00:00+01:00

# ─── Market data (FMP) ───────────────────────────────────────────────────────
FMP_API_KEY=

# ─── News headlines (NewsAPI.org — optional; free tier is delayed + rate-limited) ─
# NEWS_API_KEY=

# ─── FCA lookups (optional) ──────────────────────────────────────────────────
# FCA_API_KEY=
# FCA_API_EMAIL=
# FCA_FIRM_LOOKUP_URL=

# ─── Scripts / evals (optional) ──────────────────────────────────────────────
# ASK_EVAL_BASE_URL=http://localhost:3000
